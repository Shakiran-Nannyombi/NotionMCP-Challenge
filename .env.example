# Notion Spec-to-Ship Pipeline - Environment Configuration
# Copy this file to .env and fill in your actual values

# =============================================================================
# Notion Configuration
# =============================================================================

# Notion API Key (Integration Token)
# Get this from: https://www.notion.so/my-integrations
# 1. Create a new integration
# 2. Copy the "Internal Integration Token"
# 3. Share your Notion pages with this integration
NOTION_API_KEY=secret_your_notion_integration_token_here

# Notion MCP Server URL (if running standalone MCP server)
# Leave empty if using Kiro's built-in MCP configuration
# NOTION_MCP_URL=http://localhost:3000

# =============================================================================
# LLM Configuration (Choose ONE)
# =============================================================================

# Option 1: Groq (Fast and Free)
# Get your API key from: https://console.groq.com/
GROQ_API_KEY=your-groq-api-key-here

# Option 2: Anthropic Claude
# Get your API key from: https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# Option 3: OpenAI
# Get your API key from: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-your-openai-api-key-here

# LLM Model Selection (optional, defaults shown)
# LLM_PROVIDER=anthropic  # or "openai"
# LLM_MODEL=claude-3-5-sonnet-20241022  # or "gpt-4-turbo"
# LLM_TEMPERATURE=0.2
# LLM_TIMEOUT=120

# =============================================================================
# Pipeline Configuration
# =============================================================================

# State file location (stores pipeline runs and seen pages)
STATE_FILE=state.json

# Polling interval in seconds (how often to check Notion for new pages)
# POLL_INTERVAL=30

# Trigger detection method
# TRIGGER_PREFIX=[SHIP]  # Pages starting with this prefix will be processed
# TRIGGER_PROPERTY=pipeline_trigger  # Or use a Notion property

# =============================================================================
# Kiro Configuration
# =============================================================================

# Path to Kiro executable (if not in PATH)
# KIRO_PATH=/usr/local/bin/kiro

# Kiro command arguments (optional)
# KIRO_ARGS=--verbose

# =============================================================================
# Logging Configuration
# =============================================================================

# Log level (DEBUG, INFO, WARNING, ERROR)
# LOG_LEVEL=INFO

# Log format (json or text)
# LOG_FORMAT=json

# Log file location (optional, logs to stdout if not set)
# LOG_FILE=pipeline.log

# =============================================================================
# Development / Testing
# =============================================================================

# Enable mock mode (uses mock clients instead of real MCP/LLM)
# MOCK_MODE=false

# Test page ID (for manual testing)
# TEST_PAGE_ID=your-notion-page-id-here

# =============================================================================
# Advanced Configuration
# =============================================================================

# Retry configuration
# MAX_RETRY_ATTEMPTS=3
# RETRY_BACKOFF_BASE=1.0
# RETRY_BACKOFF_FACTOR=2.0

# Notion API rate limiting
# NOTION_RATE_LIMIT_DELAY=0.35  # seconds between consecutive API calls

# Task execution timeout
# TASK_EXECUTION_TIMEOUT=300  # seconds

# Spec generation timeout
# SPEC_GENERATION_TIMEOUT=120  # seconds
